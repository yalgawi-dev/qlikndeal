// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
enum UserRole {
  BUYER
  SELLER
  PROVIDER
  ADMIN
}

enum ServiceType {
  DELIVERY
  MOVING
  PACKING
  OTHER
}

enum ServiceRequestStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum ServiceBidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ShipmentStatus {
  DRAFT
  SHARED
  BUYER_REVIEW
  NEEDS_REVISION
  AGREED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AiStatus {
  PENDING
  PASSED
  FLAGGED
}

model User {
  id          String  @id @default(uuid()) // ─────────────────────────────────────────────────────────────
  clerkId     String? @unique // ─────────────────────────────────────────────────────────────
  email       String? @unique
  phone       String?
  idNo        String?
  firstName   String?
  lastName    String?
  imageUrl    String?
  city        String?
  street      String?
  houseNumber String?
  isGuest     Boolean @default(false)

  roles UserRole[] @default([BUYER])

  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─────────────────────────────────────────────────────────────
  shipmentsAsSeller Shipment[]     @relation("SellerShipments")
  shipmentsAsBuyer  Shipment[]     @relation("BuyerShipments")
  buyerRequests     BuyerRequest[]

  serviceProfile ServiceProviderProfile?

  // ─────────────────────────────────────────────────────────────
  listings MarketplaceListing[]

  // ─────────────────────────────────────────────────────────────
  createdTasks AdminTask[]        @relation("CreatedTasks")
  writtenNotes AdminNote[]        @relation("WrittenNotes")
  taskComments AdminTaskComment[]
}

model ServiceProviderProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  serviceTypes ServiceType[]
  displayName  String?
  bio          String?
  rating       Float         @default(0)
  reviewCount  Int           @default(0) // ─────────────────────────────────────────────────────────────

  isFixedPrice Boolean @default(false)
  basePrice    Float?

  // ─────────────────────────────────────────────────────────────
  bids ServiceBid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketplaceListing {
  id       String @id @default(uuid())
  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id])

  title       String
  description String
  price       Float
  condition   String // ─────────────────────────────────────────────────────────────
  images      String // ─────────────────────────────────────────────────────────────
  videos      String? // ─────────────────────────────────────────────────────────────
  category    String?
  extraData   String?

  // ─────────────────────────────────────────────────────────────
  latitude     Float?
  longitude    Float?
  locationName String?

  status ListingStatus @default(ACTIVE)
  listingType ListingType @default(SELL)

  viewsCount     Int @default(0)
  favoritesCount Int @default(0)

  // ─────────────────────────────────────────────────────────────
  shipments Shipment[] // ─────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ListingType {
  SELL
  BUY
}

enum ListingStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

model Shipment {
  id      String @id @default(uuid())
  shortId String @unique // ─────────────────────────────────────────────────────────────

  sellerId String
  seller   User   @relation("SellerShipments", fields: [sellerId], references: [id])

  buyerId String?
  buyer   User?   @relation("BuyerShipments", fields: [buyerId], references: [id])

  // ─────────────────────────────────────────────────────────────
  listingId String?
  listing   MarketplaceListing? @relation(fields: [listingId], references: [id])

  status ShipmentStatus @default(DRAFT)

  // ─────────────────────────────────────────────────────────────
  details   ShipmentDetails?
  agreement Agreement?

  serviceRequest ServiceRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShipmentDetails {
  id         String   @id @default(uuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  itemName      String
  value         Float
  itemCondition String // ─────────────────────────────────────────────────────────────

  sellerNotes String? // ─────────────────────────────────────────────────────────────

  aiStatus AiStatus @default(PENDING)

  images String // ─────────────────────────────────────────────────────────────
  videos String? // ─────────────────────────────────────────────────────────────

  flexibleData String? // ─────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agreement {
  id         String   @id @default(uuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  buyerAgreedAt DateTime @default(now())
  buyerIp       String?
  agreedVersion Int      @default(1)
}

model ServiceRequest {
  id         String   @id @default(uuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id])

  status      ServiceRequestStatus @default(OPEN)
  description String?

  pickupLocation  String?
  dropoffLocation String?

  // ─────────────────────────────────────────────────────────────
  bids ServiceBid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceBid {
  id        String         @id @default(uuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id])

  providerId String
  provider   ServiceProviderProfile @relation(fields: [providerId], references: [id])

  amount   Float
  currency String           @default("ILS")
  status   ServiceBidStatus @default(PENDING)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShadowLead {
  id String @id @default(uuid())

  // ─────────────────────────────────────────────────────────────
  sellerName String?
  sellerLink String?
  postText   String?
  sourceUrl  String?
  images     String? // ─────────────────────────────────────────────────────────────
  videos     String? // ─────────────────────────────────────────────────────────────

  // ─────────────────────────────────────────────────────────────
  capturedBy String? // ─────────────────────────────────────────────────────────────
  status     String  @default("NEW") // ─────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BuyerRequest {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  query  String
  status String @default("ACTIVE") // ─────────────────────────────────────────────────────────────

  extraData String? // ─────────────────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
model ParserLog {
  id String @id @default(uuid())

  // ─────────────────────────────────────────────────────────────
  originalText String @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  aiParsed String @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  // ─────────────────────────────────────────────────────────────
  userFinal String? @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  // ─────────────────────────────────────────────────────────────
  corrections String? @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  testerNote String? @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  testerImage String? @db.Text // שנה לזה

  // ─────────────────────────────────────────────────────────────
  testerName String? // ─────────────────────────────────────────────────────────────
  category   String? // ─────────────────────────────────────────────────────────────
  inputMode  String? // ─────────────────────────────────────────────────────────────
  sessionId  String? // ─────────────────────────────────────────────────────────────

  // ─────────────────────────────────────────────────────────────
  reviewed Boolean @default(false)
  quality  String? // ─────────────────────────────────────────────────────────────

  // ─────────────────────────────────────────────────────────────
  archived   Boolean   @default(false)
  archivedAt DateTime?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────

model AdminTask {
  id          String  @id @default(uuid())
  title       String
  description String?
  completed   Boolean @default(false)
  notes       String? // ─────────────────────────────────────────────────────────────

  comments AdminTaskComment[]

  createdById String?
  createdBy   User?   @relation("CreatedTasks", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminTaskComment {
  id        String    @id @default(uuid())
  taskId    String
  task      AdminTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AdminNote {
  id      String  @id @default(uuid())
  title   String? // ─────────────────────────────────────────────────────────────
  content String // ─────────────────────────────────────────────────────────────

  authorId String?
  author   User?   @relation("WrittenNotes", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────

model LaptopCatalog {
  id            String   @id @default(uuid())
  brand         String
  series        String
  modelName     String
  type          String?
  screenSize    String[] // ─────────────────────────────────────────────────────────────
  cpu           String[]
  gpu           String[]
  ram           String[]
  storage       String[]
  os            String[]
  releaseYear   String?
  notes         String?
  sku           String?  @unique
  weight        String?
  ports         String?
  display       String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([series])
}

model BrandDesktopCatalog {
  id            String   @id @default(uuid())
  brand         String
  series        String
  modelName     String
  cpu           String[]
  gpu           String[]
  ram           String[]
  storage       String[]
  os            String[]
  releaseYear   String?
  notes         String?
  sku           String?  @unique
  ports         String?
  weight        String?
  isMini        Boolean  @default(false)
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

model CustomBuildCatalog {
  id            String  @id @default(uuid())
  category      String // ─────────────────────────────────────────────────────────────
  subCategory   String?
  typicalCpu    String?
  typicalGpu    String?
  typicalRam    String?
  description   String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AioCatalog {
  id            String   @id @default(uuid())
  brand         String
  series        String
  modelName     String
  screenSize    String[]
  cpu           String[]
  gpu           String[]
  ram           String[]
  storage       String[]
  os            String[]
  releaseYear   String?
  notes         String?
  sku           String?  @unique
  display       String?
  ports         String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

model MobileCatalog {
  id               String   @id @default(uuid())
  brand            String
  series           String
  modelName        String
  sku              String?  @unique
  hebrewAliases    String[]
  storages         Int[]
  screenSize       Float?
  releaseYear      Int?
  cpu              String?
  ramG             Int?
  os               String?
  battery          String?
  rearCamera       String?
  frontCamera      String?
  weight           String?
  nfc              Boolean  @default(false)
  wirelessCharging Boolean  @default(false)
  importBatchId    String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

model VehicleCatalog {
  id            String  @id @default(uuid())
  make          String
  model         String
  year          Int?
  type          String? // ─────────────────────────────────────────────────────────────
  fuelType      String?
  transmission  String?
  engineSize    String?
  hp            Int?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([make])
  @@index([model])
}

model ElectronicsCatalog {
  id            String   @id @default(uuid())
  brand         String
  category      String // ─────────────────────────────────────────────────────────────
  modelName     String
  hebrewAliases String[]
  releaseYear   Int?
  specs         String? // ─────────────────────────────────────────────────────────────
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([category])
  @@index([modelName])
}

model ApplianceCatalog {
  id            String   @id @default(uuid())
  brand         String
  category      String // ─────────────────────────────────────────────────────────────
  modelName     String
  hebrewAliases String[]
  capacity      String? // ─────────────────────────────────────────────────────────────
  energyRating  String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([category])
  @@index([modelName])
}

model MotherboardCatalog {
  id            String  @id @default(uuid())
  brand         String
  model         String
  chipset       String?
  socket        String?
  formFactor    String?
  ramType       String?
  maxRam        String?
  pcie          String?
  m2            String?
  lan           String?
  wifi          String?
  releaseYear   String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brand, model])
  @@index([brand])
  @@index([model])
}

model GpuCatalog {
  id            String  @id @default(uuid())
  brand         String
  model         String
  chipsetBrand  String? // NVIDIA, AMD, Intel
  vramSize      String? // e.g. "12GB"
  vramType      String? // e.g. "GDDR6X"
  interface     String? // e.g. "PCIe 4.0 x16"
  powerConnectors String? // e.g. "1x 16-pin"
  recommendedPsu  String? // e.g. "750W"
  length        String? // e.g. "300mm"
  releaseYear   String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brand, model])
  @@index([brand])
  @@index([model])
}

model ScreenCatalog {
  id            String  @id @default(uuid())
  brand         String
  model         String
  size          String? // e.g. "27"
  resolution    String? // e.g. "2560x1440"
  refreshRate   String? // e.g. "144Hz"
  panelType     String? // e.g. "IPS"
  aspectRatio   String? // e.g. "16:9"
  curved        String? // e.g. "Yes" or "No"
  ports         String? // e.g. "HDMI + DP"
  releaseYear   String?
  importBatchId String?

  constraints Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brand, model])
  @@index([brand])
  @@index([model])
}

model CatalogImportLog {
  id               String   @id @default(uuid())
  category         String
  totalInFile      Int      @default(0)
  added            Int
  skipped          Int
  duplicatesInFile Int      @default(0)
  errors           Int
  errorDetails     String[] @default([])
  newTotal         Int      @default(0)
  adminName        String?
  batchId          String?  @unique
  isUndone         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────

model FieldValueReliability {
  id              String   @id @default(uuid())
  value           String
  field           String
  category        String
  confidence      Float    @default(0.5)
  occurrenceCount Int      @default(1)
  isIgnored       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique(name: "value_field_category", [value, field, category])
  @@index([category])
  @@index([createdAt]) // ליעילות ה-Pruner (סריקת תאריך)
}



model CategoryFieldThreshold {
  id               String   @id @default(uuid())
  category         String
  field            String
  threshold        Float    @default(0.8) // ─────────────────────────────────────────────────────────────
  suggestionMargin Float    @default(0.2) // ─────────────────────────────────────────────────────────────
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([category, field])
}

model ThresholdLog {
  id            String   @id @default(uuid())
  field         String
  value         String
  confidence    Float
  thresholdUsed Float
  marginUsed    Float
  actionTaken   String // ─────────────────────────────────────────────────────────────
  sourceReason  String // ─────────────────────────────────────────────────────────────
  category      String
  createdAt     DateTime @default(now())
}

model UserCorrection {
  id            String   @id @default(uuid())
  originalText  String
  predictedData Json?
  correctedData Json?
  category      String?
  adminComments String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WeightAuditLog {
  id             String  @id @default(uuid())
  category       String
  field          String
  oldWeight      Float
  newWeight      Float
  changeSource   String
  adminName      String?
  reason         String?
  isAcknowledged Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Data-Driven Enterprise Catalog & Dynamic Forms
// ─────────────────────────────────────────────────────────────

model CategoryFormStructure {
  id         String  @id @default(uuid())
  category   String // e.g. "LAPTOPS", "SMARTPHONES"
  fieldId    String // e.g. "ram", "cpu", "chassis_material"
  labelHera  String // e.g. "זיכרון RAM", "חומר המארז"
  fieldType  String // e.g. "select", "text", "number"
  order      Int     @default(0)
  isRequired Boolean @default(false)
  isDynamic  Boolean @default(false) // true if AI automatically promoted this field

  // Design Engine Columns:
  sectionName String  @default("מפרט כללי")
  sectionIcon String?
  icon        String?
  colSpan     Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, fieldId])
}

model FormFieldOption {
  id        String  @id @default(uuid())
  category  String // e.g. "LAPTOPS"
  fieldId   String // e.g. "ram"
  value     String // e.g. "16GB", "32GB"
  isDynamic Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([category, fieldId, value])
}

// ─────────────────────────────────────────────────────────────
// Signal Engine: Unified Learning Signal Registry
// Replaces: hardcoded regex rules, fragile NLP tags, static unit maps
// Powers: extractSignals(), bindNumbersToUnits() in signal-engine.ts
// ─────────────────────────────────────────────────────────────
model FieldSignal {
  id         String   @id @default(uuid())
  category   String
  field      String // e.g. "ram", "storage", "screenSize"
  rawValue   String // e.g. "גיגה", "gb", "gigabyte", "אינץ"
  normalized String // e.g. "gb", "inch"
  signalType String // VALUE | UNIT | CONTEXT | NUMBER
  weight     Float    @default(0.5)
  isIgnored  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([category, field, rawValue], name: "category_field_rawValue")
  @@index([category])
  @@index([field])
  @@index([signalType])
}

// ─────────────────────────────────────────────────────────────
// Dynamic Categories Registry (Zero Code Maintenance)
// ─────────────────────────────────────────────────────────────
model DynamicCategory {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "DRONES", "LAPTOPS"
  nameHebrew  String // e.g., "רחפנים", "לפטופים"
  prismaModel String // e.g., "electronicsCatalog"
  nlpKeywords String[] // e.g., ["drone", "drones", "רחפן"]
  regex       String // e.g., "רחפן|רחפנים|dji|mavic"
  learnFields String[] // e.g., ["brand", "modelName"]
  uniqueKeys  String[] // e.g., ["brand", "modelName"]

  translationMap Json? // e.g., { "Lenovo": ["לנובו", "Lenovo"] }

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

// ─────────────────────────────────────────────────────────────
// The "Navigation in the Dark" AI Learning Engine
// ─────────────────────────────────────────────────────────────

// Layer 1 & 3: Anchors and Compasses (הפנסים והמצפן + הצימודים)
model FieldAnchor {
  id            String   @id @default(uuid())
  phrase        String // e.g. "עולה", "עולה רק", "שח"
  category      String // e.g. "LAPTOPS" 
  relatedFields String[] // e.g. ["price", "discount"]

  // Per-field confidence — the correct solution for multi-field anchors
  // e.g. { "price": 0.82, "temperature": 0.31 }
  // The global `confidence` below is kept for backward compatibility only
  fieldConfidences Json @default("{}")

  // The Compass
  expectedType      String? // e.g. "NUMBER", "TEXT"
  expectedDirection String  @default("FORWARD") // FORWARD, BACKWARD, BOTH
  minDistance       Int     @default(1)
  maxDistance       Int     @default(5)

  // Legacy global confidence (used as fallback when fieldConfidences is empty)
  confidence      Float   @default(0.5)
  occurrenceCount Int     @default(1)
  isIgnored       Boolean @default(false)

  // Suffix/Prefix indicators
  isSuffix Boolean @default(false)
  isPrefix Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, phrase])
  @@index([category])
  @@index([phrase])
}

// Marker for Category Fingerprinting (למידת קטגוריות מונחית)
model CategoryLearningMarker {
  id              String  @id @default(uuid())
  category        String // e.g. "VEHICLES"
  markerWord      String // e.g. "טסט", "יד ראשונה"
  confidence      Float   @default(0.5)
  occurrenceCount Int     @default(1)
  isIgnored       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, markerWord])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// KNOWLEDGE BASE (LEARNING AGENT)
// ─────────────────────────────────────────────────────────────

model CapabilityMapping {
  keyword            String   @id
  keywordId          String?
  minRam             Int?
  minCpuTier         Int?
  minGpuTier         Int?
  recRam             Int?     // Recommended (not minimum) RAM from consensus
  recCpuTier         Int?     // Recommended CPU tier from consensus  
  recGpuTier         Int?     // Recommended GPU tier from consensus
  category           String?
  sourceUrl          String?  // Primary source (legacy)
  sourceUrls         String?  // JSON array of all source URLs used in consensus
  consensusScore     Float    @default(0) // 0.0-1.0 how many sources agreed
  verificationStatus String   @default("PENDING_REVIEW")
  lastUpdated        DateTime @default(now()) @updatedAt
}

model ScrapingSource {
  id          String   @id @default(uuid())
  url         String   @unique
  name        String?
  urlPattern  String?  // URL template with {query} placeholder e.g. "https://example.com/search?q={query}"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SearchFilterConfig {
  id          String   @id @default(uuid())
  filterType  String   // "STOP_WORD", "UNIT_PATTERN", "SYNONYM"
  value       String   
  replacement String?  // עבור מילים נרדפות או תבניות (למשל לנקות "GB" מ-"16GB")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([filterType, value])
}

model UnrecognizedKeyword {
  id            String   @id @default(uuid())
  keyword       String   @unique
  occurrences   Int      @default(1)
  lastSeen      DateTime @default(now())
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  createdAt DateTime @default(now())
}

model ComputerUseCategory {
  id                         Int                   @id @default(autoincrement())
  categoryNameHe             String                @map("category_name_he")
  categoryNameEn             String?               @map("category_name_en")
  description                String?
  minCpuTier                 String?               @map("min_cpu_tier")
  minRamGb                   Int                   @map("min_ram_gb")
  minStorageGb               Int                   @map("min_storage_gb")
  storageType                String                @default("SSD NVMe") @map("storage_type")
  recommendedGpu             String?               @map("recommended_gpu")
  manufacturerRecommendation String?               @map("manufacturer_recommendation")
  dynamicAttributes          Json                  @default("{}") @map("dynamic_attributes")
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @default(now()) @updatedAt @map("updated_at")
  logs                       UserConsultationLog[]
  softwareApplications       SoftwareApplication[]

  @@map("computer_use_categories")
}

model UserConsultationLog {
  id                       Int                  @id @default(autoincrement())
  userId                   String?              @map("user_id")
  selectedCategoryId       Int                  @map("selected_category_id")
  category                 ComputerUseCategory  @relation(fields: [selectedCategoryId], references: [id])
  preferredFormFactor      String?              @map("preferred_form_factor")
  userBudget               Decimal?             @map("user_budget")
  selectedListingId        String?              @map("selected_listing_id")
  aiAdjustedRecommendation Json?                @map("ai_adjusted_recommendation")
  createdAt                DateTime             @default(now()) @map("created_at")

  @@map("user_consultation_logs")
}

model SoftwareApplication {
  id                Int                  @id @default(autoincrement())
  appNameEn         String               @map("app_name_en")
  appNameHe         String?              @map("app_name_he")
  categoryId        Int?                 @map("category_id")
  category          ComputerUseCategory? @relation(fields: [categoryId], references: [id])
  minRamGbOverride  Int?                 @map("min_ram_gb_override")
  minVramGbOverride Int?                 @map("min_vram_gb_override")
  isPopular         Boolean              @default(false) @map("is_popular")
  iconUrl           String?              @map("icon_url") @db.VarChar(500)
  createdAt         DateTime             @default(now()) @map("created_at")

  @@map("software_applications")
}

model SoftwareRequest {
  id        Int      @id @default(autoincrement())
  appName   String   @map("app_name")
  isAdded   Boolean  @default(false) @map("is_added")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("software_requests")
}

